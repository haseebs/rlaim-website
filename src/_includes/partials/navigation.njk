<nav class="site-nav" aria-label="Primary">
  <ul class="site-nav__list">
    {% for item in navigation %}
      {% set isActive = item.url | isActiveNav(page.url) %}
      <li>
        <a
          class="site-nav__link{% if isActive %} site-nav__link--active{% endif %}"
          href="{{ item.url | withBaseUrl }}"
          {% if isActive %}aria-current="page"{% endif %}
        >
          {{ item.label }}
        </a>
      </li>
    {% endfor %}
  </ul>
</nav>
